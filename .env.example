# ─────────────────────────────────────────────────────────────────
# THK.MEDIA Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Admin Auth
# Generate a secure password hash with: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 12))"
ADMIN_PASSWORD_HASH=$2a$12$CHANGE_THIS_TO_YOUR_REAL_HASH

# JWT secret — make this a long random string
JWT_SECRET=change-this-to-a-long-random-secret-string-min-32-chars

# CORS — URL of your main THK.MEDIA site (no trailing slash)
ALLOWED_ORIGIN=https://thk.media

# EmailJS (optional — mirror of what's in your front-end config)
STORE_EMAIL=orders@thk.media
